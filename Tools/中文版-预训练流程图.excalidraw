      "seed": 1115924722,
      "version": 339,
      "versionNonce": 97532262,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1741652527567,
      "link": null,
      "locked": false,
      "text": "What is a release of a model?\n1) The code for running the Transformer  (e.g. 200 lines of code in Python)\n2) The parameters of the Transformer      (e.g. 1.6 billion numbers)",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
