    {
      "id": "N7BbZGf7EM1pnmxztQmVt",
      "type": "text",
      "x": 3055.048447774974,
      "y": 383.0413564519927,
      "width": 563.3193969726562,
      "height": 297,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
